---
interface Props {
  article: {
    meta: {
      company: string;
      role: string;
      startDate: Date;
      tags: string[];
    };
  };
}

const { article } = Astro.props;
const startYear = article.meta.startDate.getUTCFullYear();
---

<article class="mx-auto max-w-3xl px-4 py-12 sm:px-8 sm:py-20 lg:px-12">
  <a
    href="/projects"
    class="small-caps mb-12 inline-flex items-center gap-2 text-[10px] text-ink-400 transition-colors hover:text-flare-400 focus-visible:text-flare-400 focus-visible:outline-2 focus-visible:outline-flare-400 focus-visible:outline-offset-4"
  >
    <svg
      viewBox="0 0 16 16"
      fill="none"
      aria-hidden="true"
      class="h-3 w-3 stroke-current"
    >
      <path
        d="M7.25 11.25 3.75 8m0 0 3.5-3.25M3.75 8h8.5"
        stroke-width="1.5"
        stroke-linecap="round"
        stroke-linejoin="round"></path>
    </svg>
    Back to projects
  </a>

  <header class="mb-12">
    <div
      class="small-caps flex flex-wrap items-baseline gap-x-4 gap-y-1 text-[10px] tabular-nums text-flare-400"
    >
      <span><span class="text-flare-500">◊</span> {article.meta.role}</span>
      <time
        datetime={article.meta.startDate.toISOString()}
        class="text-ink-400"
      >
        {startYear}
      </time>
    </div>
    <h1
      class="type-architecture mt-4 font-extrabold text-ink-50"
      style="font-size: clamp(2rem, 5vw, 4rem)"
    >
      {article.meta.company}
    </h1>
    {
      article.meta.tags.length > 0 && (
        <ul class="mt-6 flex flex-wrap gap-x-3 gap-y-1">
          {article.meta.tags.map((tag: string) => (
            <li class="small-caps text-[10px] text-ink-400">{tag}</li>
          ))}
        </ul>
      )
    }
  </header>

  <div class="prose-mike" data-mdx-content>
    <slot />
  </div>
</article>
