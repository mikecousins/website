---
import { format } from 'date-fns';
import { Badge } from './catalyst/badge';

interface Project {
  id: string;
  data: {
    meta: {
      company: string;
      role: string;
      tags: string[];
      startDate: Date;
    };
  };
}

interface Props {
  projects: Project[];
}

const { projects } = Astro.props;
---

<div class="mt-8 flow-root">
  <div class="-mx-(--gutter) overflow-x-auto whitespace-nowrap">
    <div class="inline-block min-w-full align-middle sm:px-(--gutter)">
      <table class="min-w-full text-left text-sm/6 text-zinc-950 dark:text-white">
        <thead class="text-zinc-500 dark:text-zinc-400">
          <tr>
            <th class="border-b border-b-zinc-950/10 px-4 py-2 font-medium first:pl-(--gutter,--spacing(2)) last:pr-(--gutter,--spacing(2)) dark:border-b-white/10 sm:first:pl-1 sm:last:pr-1">
              Company
            </th>
            <th class="border-b border-b-zinc-950/10 px-4 py-2 font-medium first:pl-(--gutter,--spacing(2)) last:pr-(--gutter,--spacing(2)) dark:border-b-white/10 sm:first:pl-1 sm:last:pr-1">
              Role
            </th>
            <th class="border-b border-b-zinc-950/10 px-4 py-2 font-medium first:pl-(--gutter,--spacing(2)) last:pr-(--gutter,--spacing(2)) dark:border-b-white/10 sm:first:pl-1 sm:last:pr-1">
              Tags
            </th>
            <th class="border-b border-b-zinc-950/10 px-4 py-2 font-medium first:pl-(--gutter,--spacing(2)) last:pr-(--gutter,--spacing(2)) dark:border-b-white/10 sm:first:pl-1 sm:last:pr-1">
              Date
            </th>
          </tr>
        </thead>
        <tbody>
          {projects.map((project) => (
            <tr class="hover:bg-zinc-950/[2.5%] dark:hover:bg-white/[2.5%] has-[[data-row-link][data-focus]]:outline has-[[data-row-link][data-focus]]:outline-2 has-[[data-row-link][data-focus]]:-outline-offset-2 has-[[data-row-link][data-focus]]:outline-blue-500 dark:focus-within:bg-white/[2.5%]">
              <td class="relative px-4 py-4 first:pl-(--gutter,--spacing(2)) last:pr-(--gutter,--spacing(2)) border-b border-zinc-950/5 dark:border-white/5 sm:first:pl-1 sm:last:pr-1 font-medium">
                <a
                  data-row-link
                  href={`/projects/${project.id.replace('.mdx', '')}`}
                  tabindex="0"
                  class="absolute inset-0 focus:outline-hidden"
                />
                {project.data.meta.company}
              </td>
              <td class="relative px-4 py-4 first:pl-(--gutter,--spacing(2)) last:pr-(--gutter,--spacing(2)) border-b border-zinc-950/5 dark:border-white/5 sm:first:pl-1 sm:last:pr-1 font-medium">
                <a
                  data-row-link
                  href={`/projects/${project.id.replace('.mdx', '')}`}
                  tabindex="-1"
                  class="absolute inset-0 focus:outline-hidden"
                />
                {project.data.meta.role}
              </td>
              <td class="relative px-4 py-4 first:pl-(--gutter,--spacing(2)) last:pr-(--gutter,--spacing(2)) border-b border-zinc-950/5 dark:border-white/5 sm:first:pl-1 sm:last:pr-1">
                <a
                  data-row-link
                  href={`/projects/${project.id.replace('.mdx', '')}`}
                  tabindex="-1"
                  class="absolute inset-0 focus:outline-hidden"
                />
                <div class="flex gap-2">
                  {project.data.meta.tags.map((tag) => (
                    <Badge>{tag}</Badge>
                  ))}
                </div>
              </td>
              <td class="relative px-4 py-4 first:pl-(--gutter,--spacing(2)) last:pr-(--gutter,--spacing(2)) border-b border-zinc-950/5 dark:border-white/5 sm:first:pl-1 sm:last:pr-1 text-zinc-500">
                <a
                  data-row-link
                  href={`/projects/${project.id.replace('.mdx', '')}`}
                  tabindex="-1"
                  class="absolute inset-0 focus:outline-hidden"
                />
                {format(project.data.meta.startDate, 'MMMM do, yyyy')}
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </div>
</div>
