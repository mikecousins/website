---
import clsx from 'clsx';

interface Props {
  pathname: string;
}

const { pathname } = Astro.props;

const links = [
  { href: '/about', label: 'About' },
  { href: '/projects', label: 'Projects' },
  { href: '/services', label: 'Services' },
  { href: '/movies', label: 'Movies' },
];

const isActive = (href: string) =>
  pathname === href || (href !== '/' && pathname.startsWith(href));
---

<header class="sticky top-0 z-40 border-b border-ink-800/70 bg-ink-950/95 backdrop-blur-sm">
  <div
    class="flex items-baseline justify-between gap-4 px-4 py-4 sm:gap-8 sm:px-8 sm:py-5 lg:px-12"
  >
    <a
      href="/"
      class="leading-none font-extrabold tracking-tight text-ink-50 transition-colors hover:text-flare-400"
      style="font-family: var(--font-architecture); font-size: clamp(1.5rem, 3vw, 2rem)"
    >
      mike<span class="text-flare-500">.</span>
    </a>
    <nav aria-label="Primary">
      <ul
        class="flex flex-wrap items-baseline gap-x-4 gap-y-1 text-sm font-medium sm:gap-x-6"
      >
        {
          links.map((link) => (
            <li>
              <a
                href={link.href}
                aria-current={isActive(link.href) ? 'page' : undefined}
                class={clsx(
                  'group inline-flex items-baseline gap-1 transition-colors focus-visible:outline-2 focus-visible:outline-flare-400 focus-visible:outline-offset-4',
                  isActive(link.href)
                    ? 'text-flare-400'
                    : 'text-ink-100 hover:text-flare-400'
                )}
              >
                <span
                  class={clsx(
                    isActive(link.href) ? 'text-flare-300' : 'text-flare-500'
                  )}
                >
                  /
                </span>
                {link.label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>
  </div>
</header>
