---
interface Props {
  article: {
    meta: {
      title: string;
      date: Date;
    };
  };
}

const monthsLong = [
  'January', 'February', 'March', 'April', 'May', 'June',
  'July', 'August', 'September', 'October', 'November', 'December',
];

const { article } = Astro.props;
const d = article.meta.date;
const formattedDate = `${monthsLong[d.getUTCMonth()]} ${d.getUTCDate()}, ${d.getUTCFullYear()}`;
---

<article class="mx-auto max-w-3xl px-4 py-12 sm:px-8 sm:py-20 lg:px-12">
  <a
    href="/posts"
    class="small-caps mb-12 inline-flex items-center gap-2 text-[10px] text-ink-400 transition-colors hover:text-flare-400 focus-visible:text-flare-400 focus-visible:outline-2 focus-visible:outline-flare-400 focus-visible:outline-offset-4"
  >
    <svg
      viewBox="0 0 16 16"
      fill="none"
      aria-hidden="true"
      class="h-3 w-3 stroke-current"
    >
      <path
        d="M7.25 11.25 3.75 8m0 0 3.5-3.25M3.75 8h8.5"
        stroke-width="1.5"
        stroke-linecap="round"
        stroke-linejoin="round"></path>
    </svg>
    Back to the journey
  </a>

  <header class="mb-12">
    <time
      datetime={article.meta.date.toISOString()}
      class="small-caps text-[10px] tabular-nums text-flare-400"
    >
      <span class="text-flare-500">◊</span>
      {formattedDate}
    </time>
    <h1
      class="type-architecture mt-4 font-extrabold text-ink-50"
      style="font-size: clamp(2rem, 5vw, 4rem)"
    >
      {article.meta.title}
    </h1>
  </header>

  <div class="prose-mike" data-mdx-content>
    <slot />
  </div>
</article>
