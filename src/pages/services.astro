---
import BaseLayout from '../layouts/BaseLayout.astro';
import StyledLink from '../components/StyledLink.astro';

const services = [
  {
    number: '01',
    title: 'Technical Co-founder',
    body: "I have been a technical co-founder for multiple companies. I can help you get your idea off the ground, build a team, and scale your technology as your company grows.",
  },
  {
    number: '02',
    title: 'Fractional CTO',
    body: 'Need some high-level advice on your technology stack, team, or architecture? I can help. I can also help you build and scale your team.',
  },
  {
    number: '03',
    title: 'Software Development',
    body: 'Over 20 years writing software. I specialize in front-end development but I have experience across the stack. I can help you build your product from start to finish.',
  },
  {
    number: '04',
    title: 'Technical Consulting',
    body: "Other technical needs? I can help. I can do a lot of things myself and I have a large network of technical professionals I can bring in for whatever you need.",
  },
];
---

<BaseLayout title="Services — Mike Cousins">
  <section class="mx-auto max-w-6xl px-4 py-12 sm:px-8 sm:py-20 lg:px-12">
    <p class="small-caps mb-6 text-[10px] text-flare-400 sm:text-xs">
      <span class="text-flare-500">◊</span> Services
    </p>

    <h1
      class="type-architecture mb-8 font-extrabold text-ink-50"
      style="font-size: clamp(2.5rem, 6.5vw, 5.5rem)"
    >
      Four ways <span class="text-ink-500">to work together.</span>
    </h1>

    <p class="mb-20 max-w-[58ch] text-lg leading-snug text-ink-200">
      Contract software development, technical co-founder, fractional CTO
      engagements, technical consulting. Twenty-plus years across
      telecommunications, oil and gas, healthcare, finance, energy. See <StyledLink
        href="/projects">the projects</StyledLink
      > for what that's looked like in practice.
    </p>

    <ol class="grid gap-12 lg:grid-cols-2 lg:gap-x-24 lg:gap-y-20">
      {
        services.map((service) => (
          <li class="flex flex-col gap-4">
            <div class="flex items-baseline gap-6">
              <span
                class="font-extrabold text-flare-500 tabular-nums"
                style="font-family: var(--font-architecture); font-size: clamp(2.5rem, 5vw, 4rem); line-height: 0.9"
              >
                {service.number}
              </span>
              <h2
                class="text-2xl font-bold tracking-tight text-ink-50 sm:text-3xl"
                style="font-family: var(--font-architecture)"
              >
                {service.title}
              </h2>
            </div>
            <p class="max-w-[48ch] text-base leading-relaxed text-ink-200">
              {service.body}
            </p>
          </li>
        ))
      }
    </ol>

    <div class="mt-24 border-t border-ink-800 pt-12 sm:mt-32">
      <p class="max-w-[58ch] text-lg leading-snug text-ink-200">
        Want to work together? Various ways to reach me on the <StyledLink
          href="/about">about page</StyledLink
        >.
      </p>
    </div>
  </section>
</BaseLayout>
