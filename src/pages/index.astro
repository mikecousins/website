---
import { Image } from 'astro:assets';
import HomeLayout from '../layouts/HomeLayout.astro';
import portraitImage from '../images/ski.jpg';
import GitHubIcon from '../components/icons/GitHubIcon.astro';
import LinkedInIcon from '../components/icons/LinkedInIcon.astro';
import MailIcon from '../components/icons/MailIcon.astro';
import CalendarIcon from '../components/icons/CalendarIcon.astro';

const navLinks = [
  { href: '/about', label: 'About' },
  { href: '/projects', label: 'Projects' },
  { href: '/services', label: 'Services' },
];
---

<HomeLayout title="Mike Cousins">
  <main
    class="relative h-svh w-screen overflow-hidden bg-ink-950 text-ink-100"
  >
    {/* The architectural block: orange vertical band, anchored right. */}
    <div
      class="absolute inset-y-0 right-0 w-full sm:w-[42%] bg-flare-500 top-[62svh] sm:top-0"
      aria-hidden="true"
    >
    </div>

    {/* Portrait crop inside the orange band. Larger, full-bleed of the band, treated as architectural plate. */}
    <div
      class="absolute right-0 top-[65svh] sm:top-[14svh] aspect-[3/4] h-[35svh] sm:h-[64svh] w-auto overflow-hidden"
    >
      <Image
        src={portraitImage}
        alt="Mike, mid-powder, somewhere west of Calgary."
        widths={[400, 600, 900]}
        sizes="(max-width: 640px) 45vw, 28vw"
        class="absolute inset-0 h-full w-full object-cover object-center grayscale contrast-110 brightness-105 mix-blend-multiply"
      />
      {/* Hot wash drives the duotone toward the flare hue. */}
      <div
        class="absolute inset-0 bg-flare-500 mix-blend-color opacity-85"
        aria-hidden="true"
      >
      </div>
    </div>

    {/* The name as architecture. Two stacked monumental lines.
        Font-size caps on both width (19vw) and height (32svh) so the type
        can't outgrow the viewport on wide-but-short laptop windows. */}
    <h1
      class="absolute left-[clamp(0.75rem,4vw,4rem)] top-[clamp(7svh,8svh,11svh)] sm:top-[clamp(14svh,18svh,22svh)] font-display font-extrabold type-architecture text-ink-50 select-none pointer-events-none z-10"
      style="font-size: clamp(4.5rem, min(19vw, 32svh), 24rem)"
    >
      <span class="block">mike<span class="text-flare-500">.</span></span>
      <span class="block translate-x-[0.18em] -mt-[0.14em]"
        >cousins<span class="text-flare-500">.</span></span
      >
    </h1>

    {/* Top-left marginalia: place and coordinates. */}
    <div
      class="absolute top-[3svh] left-[clamp(0.75rem,4vw,4rem)] small-caps text-[10px] sm:text-xs text-ink-300 z-20"
    >
      <span class="text-flare-400">◊</span> Calgary
      <span class="hidden sm:inline">· 51.0°N · 114.0°W</span>
    </div>

    {/* Top-right marginalia: role kicker, sits inside the orange band on desktop. */}
    <div
      class="absolute top-[3svh] right-[clamp(0.75rem,4vw,4rem)] text-right small-caps text-[10px] sm:text-xs leading-relaxed z-20 text-ink-300 sm:text-ink-950/85"
    >
      <div>Architect.</div>
      <div>Developer.</div>
      <div>Fractional CTO.</div>
    </div>

    {/* Supporting sentence on mobile only. Sits between the name and the orange band. */}
    <p
      class="absolute left-[clamp(0.75rem,4vw,4rem)] top-[34svh] max-w-[28ch] text-base leading-snug text-ink-200 z-20 sm:hidden"
    >
      Twenty-plus years building software. Early-stage startup junkie,
      fractional CTO, contract mercenary. Calgary based, mostly reachable.
    </p>

    {/* Bottom-left info column: bio · tenure stamp · primary nav.
        On mobile the stack sits on the orange band (paragraph is rendered above);
        on desktop the bio joins the stack so it never collides with the headline. */}
    <div
      class="absolute bottom-[3svh] left-[clamp(0.75rem,4vw,4rem)] z-20 flex flex-col gap-3 sm:gap-5 max-w-[55vw] sm:max-w-none"
    >
      <p
        class="hidden sm:block max-w-[36ch] text-base leading-snug text-ink-200"
      >
        Twenty-plus years building software. Early-stage startup junkie,
        fractional CTO, contract mercenary. Calgary based, mostly reachable.
      </p>
      <div class="small-caps text-[10px] text-ink-950/70 sm:text-ink-400">
        <span class="text-ink-950/60 sm:text-flare-400">▸</span> Practicing since
        2003
      </div>
      <nav aria-label="Primary">
        <ul
          class="flex flex-wrap gap-x-5 gap-y-1 text-sm font-medium text-ink-950 sm:text-ink-100"
        >
          {
            navLinks.map((link) => (
              <li>
                <a
                  href={link.href}
                  class="group inline-flex items-baseline gap-1 transition-colors hover:text-ink-950/60 focus-visible:text-ink-950/60 sm:hover:text-flare-400 sm:focus-visible:text-flare-400 focus-visible:outline-2 focus-visible:outline-ink-950 sm:focus-visible:outline-flare-400 focus-visible:outline-offset-4"
                >
                  <span class="text-ink-950/70 sm:text-flare-500 group-hover:text-ink-950/40 sm:group-hover:text-flare-300">
                    /
                  </span>
                  {link.label}
                </a>
              </li>
            ))
          }
        </ul>
      </nav>
    </div>

    {/* Bottom-right: social icons, sit on the orange (so dark) on desktop, dark grey on mobile. */}
    <div
      class="absolute bottom-[3svh] right-[clamp(0.75rem,4vw,4rem)] z-20 flex items-center gap-5"
    >
      <a
        href="https://github.com/mikecousins"
        aria-label="GitHub"
        class="text-ink-900 transition-colors hover:text-ink-950 focus-visible:text-ink-950 focus-visible:outline-2 focus-visible:outline-ink-950 focus-visible:outline-offset-4 sm:text-ink-950/85 sm:hover:text-ink-950"
      >
        <GitHubIcon className="h-5 w-5 fill-current" />
      </a>
      <a
        href="https://www.linkedin.com/in/mikecousins"
        aria-label="LinkedIn"
        class="text-ink-900 transition-colors hover:text-ink-950 focus-visible:text-ink-950 focus-visible:outline-2 focus-visible:outline-ink-950 focus-visible:outline-offset-4 sm:text-ink-950/85 sm:hover:text-ink-950"
      >
        <LinkedInIcon className="h-5 w-5 fill-current" />
      </a>
      <a
        href="mailto:mike@cousins.ai"
        aria-label="Email Mike"
        class="text-ink-900 transition-colors hover:text-ink-950 focus-visible:text-ink-950 focus-visible:outline-2 focus-visible:outline-ink-950 focus-visible:outline-offset-4 sm:text-ink-950/85 sm:hover:text-ink-950"
      >
        <MailIcon className="h-5 w-5 fill-current" />
      </a>
      <a
        href="https://cal.com/mikecousins"
        aria-label="Book a meeting with Mike"
        class="text-ink-900 transition-colors hover:text-ink-950 focus-visible:text-ink-950 focus-visible:outline-2 focus-visible:outline-ink-950 focus-visible:outline-offset-4 sm:text-ink-950/85 sm:hover:text-ink-950"
      >
        <CalendarIcon className="h-5 w-5 fill-current" />
      </a>
    </div>

    {/* A vertical manifesto line set on the orange band, in dark ink for contrast. */}
    <div
      class="hidden sm:flex absolute right-[40%] top-1/2 -translate-y-1/2 z-10 small-caps text-[10px] text-ink-950/70 [writing-mode:vertical-rl] rotate-180 tracking-[0.32em] whitespace-nowrap pointer-events-none"
      aria-hidden="true"
    >
      ◊ Open to interesting work · MMXXVI · Calgary 51°N
    </div>
  </main>
</HomeLayout>
