---
import BaseLayout from '../layouts/BaseLayout.astro';
import { movies } from '../../app/data/movies';
import { MoviesTable } from '../components/MoviesTable';

const watched = movies.filter((movie) => !!movie.watched).length;
const percent = Math.round((watched / movies.length) * 100);
---

<BaseLayout
  title="IMDb Top 250 — Mike Cousins"
  description="A bucket-list endeavour to watch the IMDb Top 250."
>
  <section class="mx-auto max-w-6xl px-4 py-12 sm:px-8 sm:py-20 lg:px-12">
    <p class="small-caps mb-6 text-[10px] text-flare-400 sm:text-xs">
      <span class="text-flare-500">◊</span> Movies
    </p>

    <h1
      class="type-architecture mb-8 font-extrabold text-ink-50"
      style="font-size: clamp(2.5rem, 6.5vw, 5.5rem)"
    >
      IMDb Top 250.
    </h1>

    <p class="mb-12 max-w-[58ch] text-lg leading-snug text-ink-200">
      Bucket-list endeavour to watch the best movies ever made. Tracked here as
      I go.
    </p>

    <div
      class="mb-16 grid grid-cols-2 gap-6 border-y border-ink-800 py-8 sm:grid-cols-4 sm:gap-12"
    >
      <div>
        <p class="small-caps text-[10px] text-ink-400">Watched</p>
        <p
          class="mt-1 tabular-nums text-ink-50"
          style="font-family: var(--font-architecture); font-size: clamp(2rem, 4vw, 3.5rem); font-weight: 800; line-height: 1"
        >
          {watched}
        </p>
      </div>
      <div>
        <p class="small-caps text-[10px] text-ink-400">Remaining</p>
        <p
          class="mt-1 tabular-nums text-ink-300"
          style="font-family: var(--font-architecture); font-size: clamp(2rem, 4vw, 3.5rem); font-weight: 800; line-height: 1"
        >
          {movies.length - watched}
        </p>
      </div>
      <div>
        <p class="small-caps text-[10px] text-ink-400">Progress</p>
        <p
          class="mt-1 tabular-nums text-flare-500"
          style="font-family: var(--font-architecture); font-size: clamp(2rem, 4vw, 3.5rem); font-weight: 800; line-height: 1"
        >
          {percent}<span class="text-flare-700">%</span>
        </p>
      </div>
      <div>
        <p class="small-caps text-[10px] text-ink-400">Total</p>
        <p
          class="mt-1 tabular-nums text-ink-300"
          style="font-family: var(--font-architecture); font-size: clamp(2rem, 4vw, 3.5rem); font-weight: 800; line-height: 1"
        >
          {movies.length}
        </p>
      </div>
    </div>

    <div
      class="w-full overflow-x-auto whitespace-nowrap font-mono"
      style="font-family: ui-monospace, SFMono-Regular, Menlo, monospace"
    >
      <div
        class="small-caps flex border-b border-ink-800 text-[10px] text-ink-400"
      >
        <div class="px-2 py-3 sm:px-4">#</div>
        <div class="flex-1 px-2 py-3 sm:px-4">Title</div>
        <div class="px-2 py-3 sm:px-4">Resolution</div>
      </div>
      <MoviesTable movies={movies} client:load />

    </div>
  </section>
</BaseLayout>
