---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = 'Mike Cousins. Architect, developer, fractional CTO. Calgary.',
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <script
      is:inline
      id="counterscale-script"
      data-site-id="mikecousins"
      src="https://counterscale.cousins.ai/tracker.js"
      defer></script>
  </head>
  <body class="bg-ink-950 text-ink-100 font-sans antialiased overflow-hidden">
    <slot />
    <script>
      // Curious visitors: hello.
      const banner = [
        '',
        '  m i k e .',
        '  c o u s i n s .',
        '',
        '  architect / developer / fractional CTO',
        '  calgary  ·  51.0°N',
        '',
        '  mike@cousins.ai  ·  cal.com/mikecousins',
        '',
      ].join('\n');
      // eslint-disable-next-line no-console
      console.log(
        '%c' + banner,
        'color: oklch(0.72 0.21 50); font-family: ui-monospace, monospace; font-size: 12px; line-height: 1.4;'
      );
    </script>
  </body>
</html>
